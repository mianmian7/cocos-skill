{
    "$schema": "./@types/schema/package/index.json",
    "package_version": 2,
    "name": "cocos-skill",
    "version": "1.0.0",
    "author": "mianmian7",
    "editor": ">=3.8.6",
    "scripts": {
        "preinstall": "node ./scripts/preinstall.js",
        "prebuild": "node ./scripts/ensure-esbuild-platform.mjs",
        "build": "node esbuild.config.mjs",
        "build:tsc": "npx tsc",
        "build:watch": "npx tsc --watch",
        "package": "node scripts/package.mjs",
        "qa:no-legacy": "node scripts/qa/assert-no-legacy-identifiers.mjs"
    },
    "description": "cocos-skill extension with HTTP REST API and Python CLI for Cocos Creator",
    "main": "./dist/main.js",
    "dependencies": {
        "express": "^4.18.2",
        "fs-extra": "^10.0.0",
        "vue": "^3.1.4",
        "zod": "^3.22.0"
    },
    "devDependencies": {
        "@cocos/creator-types": "^3.8.6",
        "@types/express": "^4.17.17",
        "@types/fs-extra": "^9.0.5",
        "@types/node": "^18.17.1",
        "esbuild": "^0.27.2",
        "typescript": "^5.8.2"
    },
    "contributions": {
        "scene": {
            "script": "./dist/scene/index.js"
        },
        "messages": {
            "start-skill-server": {
                "methods": [
                    "startHttpServer"
                ]
            },
            "stop-skill-server": {
                "methods": [
                    "stopHttpServer"
                ]
            },
            "get-skill-server-info": {
                "methods": [
                    "getHttpServerInfo"
                ]
            },
            "update-skill-server-config": {
                "methods": [
                    "updateHttpServerConfig"
                ]
            }
        }
    }
}
